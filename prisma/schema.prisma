// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  password           String
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Account {
  id           String   @id @default(uuid())
  platform     String   @unique // e.g., "tiktok"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  updatedAt    DateTime @updatedAt
}

model Source {
  id          String    @id @default(uuid())
  name        String
  url         String    @unique
  type        String    // "rss" or "web"
  lastScraped DateTime?
  articles    Article[]
}

model Article {
  id             String   @id @default(uuid())
  title          String
  link           String   @unique
  contentSnippet String?
  pubDate        String?
  status         String   @default("scraped") // scraped, summarized, video_generated, posted
  script         Json?     // Native JSON support for better performance and flexibility
  imageUrl       String?
  videoId        String?
  sourceId       String?
  source         Source?  @relation(fields: [sourceId], references: [id])
  video          Video?   @relation(fields: [videoId], references: [id])
  createdAt      DateTime @default(now())
}

model Video {
  id          String    @id @default(uuid())
  title       String
  videoUrl    String
  audioUrl    String
  status      String    @default("ready") // ready, posted
  source      String    @default("internal") // internal, manager
  publishId   String?
  platforms   String?   // comma-separated
  createdAt   DateTime  @default(now())
  postedAt    DateTime?
  articles    Article[]
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // Store as string or JSON string
  updatedAt DateTime @updatedAt
}

model Asset {
  id        String   @id @default(uuid())
  name      String
  size      Int
  hash      String   @unique // CRC32 or SHA-256
  url       String
  type      String   // "image", "video", "audio"
  createdAt DateTime @default(now())
}

model Voice {
  id        String   @id @default(uuid())
  voiceId   String   // Provider's voice ID (e.g., "1402")
  name      String   // Display name (e.g., "Thế Hào")
  provider  String   // "ohfree", "edge", "elevenlabs", etc.
  createdAt DateTime @default(now())

  @@unique([voiceId, provider])
}

model VideoTask {
  id          String   @id @default(uuid())
  articleId   String?
  templateId  String   @default("classic")
  title       String?
  content     String?  @db.Text
  script      String?  @db.Text
  imageUrl    String?
  ttsProvider String   @default("edge")
  ttsVoiceId  String   @default("vi-VN-HoaiMyNeural")
  bgmAssetId  String?
  bgmVolume   Float?   @default(0.15)
  ratio       String   @default("9:16")
  status      String   @default("pending") // pending, processing, completed, error
  source      String   @default("internal") // internal, manager
  error       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status, createdAt])
}
