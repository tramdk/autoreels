# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI model overrides (optional — defaults shown below)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_HTML_MODEL=gemini-2.0-flash
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TikTok API Credentials
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# ElevenLabs TTS (https://elevenlabs.io/app/settings/api-keys)
# Free: 10,000 chars/month — dev/test only, no commercial license
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="pNInz6obpgDQGcFmaJgB"

#CLOUDINARY CONFIG
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""